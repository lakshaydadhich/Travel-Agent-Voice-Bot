# ── LiveKit Cloud ─────────────────────────────────────────────
# Get these from https://cloud.livekit.io → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_api_secret_here

# ── Google AI (for Gemini itinerary) ─────────────────────────
# Get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── AviationStack (flight search) ────────────────────────────
# Get from https://aviationstack.com — free: 500 req/month
AVIATIONSTACK_KEY=your_aviationstack_key_here

# ── Geoapify (hotels & places) ───────────────────────────────
# Get from https://myprojects.geoapify.com — free: 3000 req/day
GEOAPIFY_KEY=your_geoapify_key_here

# ── WeatherAPI (current weather) ─────────────────────────────
# Get from https://www.weatherapi.com — free: 1M calls/month
WEATHERAPI_KEY=your_weatherapi_key_here

# ── Agent Config (optional) ──────────────────────────────────
AGENT_DISPATCH_NAME=travel-agent
